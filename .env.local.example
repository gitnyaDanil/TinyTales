# Copy this file to .env.local — Next.js reads it automatically.
# This file IS committed to git. Never commit .env.local itself.

# ── Option A: DeepSeek (cloud) ──────────────────────────────────────────────
# Get your key at: https://platform.deepseek.com/api_keys
# Default model: deepseek-v4-flash (note: deepseek-chat deprecated July 24 2026)
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# ── Option B: LM Studio (local model) ────────────────────────────────────────
# 1. Open LM Studio → Local Server tab → Start Server
# 2. Enable "Serve on Local Network"
# 3. Set the URL shown by LM Studio below (e.g. http://192.168.x.x:1234/v1)
# OPENAI_BASE_URL=http://127.0.0.1:1234/v1
# OPENAI_MODEL=local-model
# DEEPSEEK_API_KEY=lm-studio

# ── Option C: OpenAI ─────────────────────────────────────────────────────────
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4o-mini
# DEEPSEEK_API_KEY=your_openai_key_here
